{
  "gameName": "PlayPltx",
  "schemaType": "Unified Event Logging",
  "fixedEnvelope": {
    "userId": "string (UUID)",
    "sessionId": "string (UUID)",
    "condition": "string (A/B)",
    "timestamp": "ISO8601 / Firestore Timestamp",
    "eventType": "string"
  },
  "events": [
    {
      "eventType": "game_start",
      "description": "נשלח ברגע שהמשחק נטען ומוגדר ה-Condition של המשתמש",
      "eventParams": {
        "initialCoins": "int",
        "initialEnergy": "int",
        "currentVillageId": "int",
        "version": "string"
      }
    },
    {
      "eventType": "slot_spin_result",
      "description": "נשלח בכל פעם שהגלגלים עוצרים (התוצאה נקבעת לפני האנימציה)",
      "eventParams": {
        "reels": "array [string, string, string]",
        "payout": "int",
        "energyBefore": "int",
        "energyAfter": "int",
        "actionTriggered": "string (attack|raid|shield|null)",
        "isCombo": "boolean"
      }
    },
    {
      "eventType": "action_attack",
      "description": "נשלח בסיום תקיפה (אחרי 3 פטישים)",
      "eventParams": {
        "targetBotId": "string",
        "targetBuilding": "string (castle|cannon|farm|statue|boat)",
        "result": "string (hit|blocked)",
        "reward": "int",
        "targetLevelBefore": "int"
      }
    },
    {
      "eventType": "action_raid",
      "description": "נשלח בסיום שוד (אחרי 3 חזירים)",
      "eventParams": {
        "totalStolen": "int",
        "perfectRaid": "boolean (אם מצא את כל 3 בורות הכסף)",
        "attempts": "int (1-3)",
        "opponentWealth": "int"
      }
    },
    {
      "eventType": "shield_gain",
      "description": "נשלח כשהמשתמש מקבל מגן מהסלוט",
      "eventParams": {
        "shieldsBefore": "int",
        "shieldsAfter": "int",
        "isMaxed": "boolean"
      }
    },
    {
      "eventType": "village_upgrade",
      "description": "נשלח בכל פעם שמשתמש קונה 'כוכב' למבנה",
      "eventParams": {
        "itemType": "string (castle|cannon|farm|boat|statue)",
        "levelBefore": "int",
        "levelAfter": "int",
        "cost": "int",
        "totalVillageStars": "int"
      }
    },
    {
      "eventType": "village_complete",
      "description": "נשלח כשהמשתמש מסיים את כל 25 הכוכבים ועובר אי",
      "eventParams": {
        "completedVillageId": "int",
        "nextVillageId": "int",
        "spinsUsedInVillage": "int",
        "playtimeInVillageSeconds": "float"
      }
    },
    {
      "eventType": "energy_refill",
      "description": "נשלח כשהמשתמש מבצע רענון אנרגיה (ידני או אוטומטי)",
      "eventParams": {
        "source": "string (button_click|time_reward|bonus)",
        "amountGained": "int"
      }
    }
  ]
}