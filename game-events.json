{
  "meta": {
    "title": "PlayPLTX analytics event definitions",
    "transport": "logEvent(name, props) → saveToFirestore; envelope fields are merged by the logger",
    "note": "Valid JSON: use this file for codegen, docs, and validation."
  },
  "version": "2.0",
  "currentAppVersion": "1.0.8",
  "source": "index.html",

  "getSuperProperties": {
    "description": "Returned from getSuperProperties(); merged from window.userProperties + dynamic fields and written as top-level document fields (not inside eventParams).",
    "properties": {
      "version": { "type": "string", "source": "APP_VERSION constant in index.html (manual update point)" },
      "platform": { "type": "string", "enum": ["Mobile", "Tablet", "Desktop"], "source": "navigator.userAgent classification" },
      "countryCode": { "type": "string", "source": "ipapi country_code; fallback unknown" },
      "userId": { "type": "string", "source": "gameState.userId (initialized from USER_ID)" },
      "playerName": { "type": "string", "source": "gameState.playerName (persistent nickname via localStorage key playerName)" },
      "condition": { "type": "string", "source": "gameState.condition" },
      "currentLevel": { "type": "number", "source": "Alias of gameState.villageId (same value as currentVillage)" },
      "currentVillage": { "type": "number", "source": "gameState.villageId" },
      "timestamp": { "type": "string", "source": "new Date().toISOString() at event time" },
      "clientTimestampMs": { "type": "number", "source": "Date.now() at event time" },
      "sessionId": { "type": "string", "source": "window.__researchContext.sessionId" },
      "sessionIndex": { "type": "integer", "source": "gameState.currentSessionIndex; increments once per new session_start and persists in localStorage" },
      "eventIndex": { "type": "integer", "source": "gameState.currentEventIndex; increments on every logged event within a session and resets at session_start" }
    }
  },

  "envelope": {
    "description": "Every persisted row: super columns + eventParams string containing only event-specific keys from logEvent(name, params).",
    "properties": [
      {
        "name": "userId",
        "type": "string",
        "required": true,
        "source": "getSuperProperties().userId or __researchContext.userId"
      },
      {
        "name": "sessionId",
        "type": "string",
        "required": true,
        "source": "window.__researchContext.sessionId"
      },
      {
        "name": "sessionIndex",
        "type": "integer",
        "required": true,
        "description": "Global running session counter per user; increments once at each new session_start"
      },
      {
        "name": "eventIndex",
        "type": "integer",
        "required": true,
        "description": "Within-session event sequence number; starts at 1 and increments on each event"
      },
      {
        "name": "condition",
        "type": "string",
        "required": true,
        "description": "CFG / A-B condition id",
        "source": "getSuperProperties().condition or __researchContext.condition"
      },
      {
        "name": "playerName",
        "type": "string",
        "required": true,
        "description": "Display nickname for leaderboard; persisted in localStorage",
        "source": "getSuperProperties().playerName"
      },
      {
        "name": "timestamp",
        "type": "string",
        "required": true,
        "format": "ISO-8601",
        "source": "new Date().toISOString() at write time (ingest time)"
      },
      { "name": "eventName", "type": "string", "required": true, "description": "Same as the event key in this file" },
      {
        "name": "eventParams",
        "type": "string",
        "required": true,
        "description": "JSON.stringify(params) only — event-specific fields, no userId/condition/level/village/platform"
      },
      {
        "name": "currentLevel",
        "type": "integer",
        "required": true,
        "source": "getSuperProperties().currentLevel"
      },
      {
        "name": "currentVillage",
        "type": "integer",
        "required": true,
        "source": "getSuperProperties().currentVillage"
      },
      {
        "name": "clientTimestampMs",
        "type": "integer",
        "required": true,
        "source": "getSuperProperties().timestamp (Date.now() at event time)"
      },
      {
        "name": "platform",
        "type": "string",
        "required": true,
        "source": "getSuperProperties().platform"
      },
      {
        "name": "countryCode",
        "type": "string",
        "required": true,
        "source": "getSuperProperties().countryCode"
      },
      {
        "name": "version",
        "type": "string",
        "required": true,
        "source": "getSuperProperties().version"
      }
    ]
  },

  "superProperties": {
    "description": "Top-level Firestore fields merged from window.userProperties + dynamic runtime properties.",
    "list": ["userId", "playerName", "sessionId", "sessionIndex", "eventIndex", "condition", "timestamp", "eventName", "currentLevel", "currentVillage", "clientTimestampMs", "platform", "countryCode", "version", "eventParams"]
  },

  "types": {
    "BuildingId": "Castle | Cannon | Statue | Farm | Boat",
    "ActionResult": "success | failure | max",
    "EnergyKind": "refill | depleted_modal | dev_refill",
    "TravelPhase": "started | ended"
  },

  "events": {
    "session_start": {
      "description": "Session ready after consent; replaces legacy consent + setup + game_start.",
      "properties": {
        "initialSpins": { "type": "number", "required": true },
        "initialCoins": { "type": "number", "required": true },
        "consent": { "type": "boolean", "required": true, "description": "true on normal consent path" }
      }
    },
    "session_end": {
      "description": "Fired when the user leaves the page (best-effort). Session duration is derived in BigQuery from session_start vs session_end.",
      "properties": {
        "totalSessionTime": { "type": "number", "required": true },
        "finalLevel": { "type": "number", "required": true },
        "finalCoins": { "type": "number", "required": true }
      }
    },
    "building_upgrade": {
      "description": "Triggered when a player attempts to add a star to a village building.",
      "properties": {
        "status": { "type": "ActionResult", "required": true },
        "building": { "type": "BuildingId", "required": true, "description": "Strict canonical building ids only" },
        "levelAfter": { "type": "number", "required": false, "description": "Usually absent on failure" },
        "cost": { "type": "number", "required": false },
        "isFree": { "type": "boolean", "required": false },
        "reason": {
          "type": "string",
          "required": false,
          "enum": ["capped_by_castle", "not_enough_coins", "already_max", "wall_not_owned"]
        },
        "levelBefore": { "type": "number", "required": false },
        "cannonIndex": { "type": "number", "required": false, "description": "1 | 2" },
        "cannonLevelAfter": { "type": "number", "required": false },
        "farmLevelAfter": { "type": "number", "required": false },
        "castleStageBefore": { "type": "number", "required": false },
        "castleStageAfter": { "type": "number", "required": false },
        "source": { "type": "string", "required": false, "enum": ["wall_unlock_purchase"] }
      }
    },
    "spin": {
      "description": "The core gameplay event. Fired whenever a slot spin finishes and rewards are calculated.",
      "properties": {
        "spinIndex": { "type": "number", "required": true },
        "energyBefore": { "type": "number", "required": true },
        "energyAfter": { "type": "number", "required": true },
        "symbols": { "type": "array", "items": { "type": "string" }, "required": true },
        "payoutCoins": { "type": "number", "required": true },
        "actionTriggered": {
          "type": ["string", "null"],
          "required": true,
          "enum": ["raid", "attack", "shield", null]
        },
        "detailedResult": { "type": "string", "required": true },
        "spinsBonus": { "type": "number", "required": true, "description": "0 if no triple-Spins row" },
        "reactionTimeMs": { "type": "number", "required": true }
      }
    },
    "attack_start": {
      "description": "Attack flow started after triple hammers.",
      "properties": {
        "targetName": { "type": "string", "required": true },
        "targetUserId": { "type": "string", "required": true }
      }
    },
    "attack_end": {
      "description": "Attack flow resolved after target selection.",
      "properties": {
        "targetName": { "type": "string", "required": true },
        "result": { "type": "string", "required": true, "enum": ["hit", "blocked"] },
        "reward": { "type": "number", "required": true },
        "buildingName": { "type": "string", "required": true }
      }
    },
    "raid_start": {
      "description": "Raid mode entered after triple pigs.",
      "properties": {
        "rivalName": { "type": "string", "required": true },
        "raidStealCap": { "type": "number", "required": true, "description": "Scaled maximum coins stealable this raid (village-scaled)" }
      }
    },
    "raid_end": {
      "description": "Raid result after the third dig.",
      "properties": {
        "totalStolen": { "type": "number", "required": true },
        "perfectRaid": { "type": "boolean", "required": true },
        "reward": { "type": "number", "required": false, "description": "Optional compatibility mirror of totalStolen" }
      }
    },
    "energy_update": {
      "description": "Spin timer refill, out-of-spins modal, or dev refill.",
      "properties": {
        "kind": { "type": "EnergyKind", "required": true },
        "spinsBefore": { "type": "number", "required": false, "description": "refill" },
        "spinsAfter": { "type": "number", "required": true },
        "nextRefillTime": { "type": "number", "required": false, "description": "epoch ms; refill + depleted_modal" },
        "spins": { "type": "number", "required": false, "description": "depleted_modal only" }
      }
    },
    "tutorial_progress": {
      "description": "Main tutorial steps and mini-tutorial completion.",
      "properties": {
        "phase": { "type": "string", "required": true, "description": "e.g. start, continue_click, skip_click, mini_complete" },
        "stepNumber": { "type": "number", "required": false },
        "timeSpent": { "type": "number", "required": false, "description": "ms on step" },
        "totalSpins": { "type": "number", "required": false, "description": "mini_complete" }
      }
    },
    "village_complete": {
      "description": "Sole progression event: 25 stars collected for current village; client then advances level and next village.",
      "properties": {
        "villageId": { "type": "number", "required": true },
        "totalSpins": { "type": "number", "required": true },
        "timeSpent": { "type": "number", "required": true, "description": "seconds in village" }
      }
    },
    "audit_stress_test": {
      "description": "Dev harness runStressTest only.",
      "properties": {
        "hasEconomy": { "type": "boolean", "required": true },
        "hasLogger": { "type": "boolean", "required": true },
        "hasRunSpin": { "type": "boolean", "required": true },
        "hasAddStar": { "type": "boolean", "required": true }
      }
    }
  },

  "eventNames": [
    "audit_stress_test",
    "attack_end",
    "attack_start",
    "building_upgrade",
    "energy_update",
    "raid_end",
    "raid_start",
    "session_end",
    "session_start",
    "spin",
    "tutorial_progress",
    "village_complete"
  ],

  "notEmitted": [
    {
      "name": "player_level_up",
      "reason": "Removed in v1.0.6; progression is logged only via village_complete"
    },
    {
      "name": "economy_config_loaded",
      "reason": "Removed from lean pipeline"
    },
    {
      "name": "upgrade_modal_opened",
      "reason": "Removed from lean pipeline"
    }
  ]
}
